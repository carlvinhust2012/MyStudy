===============================================================================
                    完整调用链总结
===============================================================================

  PaloFe.main()
    |
    +-- QeService.start()
    |     +-- MysqlServer.Listener.run()       [接受 MySQL 连接]
    |
    +-- ConnectScheduler.LoopHandler.run()
    |     +-- MysqlProto.negotiate()            [MySQL 握手/认证]
    |     +-- ConnectProcessor.loop()
    |           +-- dispatch() -> handleQuery() [COM_QUERY]
    |           +-- SqlParser.parse()           [SQL -> AST]
    |
    +-- StmtExecutor.execute()
    |     +-- analyze()
    |     |     +-- SelectStmt.analyze()        [语义分析]
    |     |     +-- ExprRewriter.apply()        [表达式重写 RBO]
    |     |     +-- StmtRewriter.rewrite()      [子查询展开]
    |     |
    |     +-- Planner.plan()
    |     |     +-- SingleNodePlanner           [AST -> PlanNode 树]
    |     |     +-- MaterializedViewSelector    [物化视图重写]
    |     |     +-- DistributedPlanner          [PlanNode -> Fragment]
    |     |     +-- RuntimeFilterGenerator      [运行时过滤]
    |     |
    |     +-- Coordinator.exec()
    |     |     +-- prepare()
    |     |     +-- computeScanRangeAssignment() [Tablet 分配]
    |     |     +-- computeFragmentExecParams()
    |     |     +-- sendFragment()             [RPC -> BE]
    |     |
    |     +-- coord.getNext() 循环             [拉取结果]
    |           +-- fetch_data RPC -> BE
    |           +-- channel.sendOnePacket() -> MySQL Client
    |
    +-- BE: FragmentMgr -> PlanFragmentExecutor
          +-- prepare() -> ExecNode::create_tree()
          +-- open() -> _plan->open()
          +-- get_next() 循环 -> Block
          +-- VDataStreamSender.send() -> ExchangeNode (Fragment 间)
          +-- ResultBufferMgr.fetch_data() -> FE (结果返回)
          +-- coordinator_callback() -> reportExecStatus (状态汇报)

